# @author nikoeleison

#--- font
URxvt.font: xft:LiberationMono:size=11:antialias=true
URxvt.boldFont: xft:LiberationMono-Bold:bold:size=11:antialias=true

#--- scroll
# disable scroll ui
URxvt.scrollBar: false

#--- keybind
# move between word using ctrl + left/right
URxvt.keysym.Control-Left: \033[1;5D
URxvt.keysym.Control-Right: \033[1;5C
