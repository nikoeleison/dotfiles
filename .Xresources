# @author nikoeleison

#--- font
URxvt.font: xft:UbuntuMono-R:size=12:antialias=true
URxvt.boldFont: xft:UbuntuMono-B:bold:size=12:antialias=true

#--- scroll
# disable scroll ui
URxvt.scrollBar: false

#--- keybind
# move between word using ctrl + left/right
URxvt.keysym.Control-Left: \033[1;5D
URxvt.keysym.Control-Right: \033[1;5C
