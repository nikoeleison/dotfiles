#--- global
separator=false
separator_block_width=10

[netspeed]
command=sh ~/.config/i3/script/netspeed.sh
interval=1

[temperature]
command=sh ~/.config/i3/script/temperature.sh
interval=10

[cpu]
command=sh ~/.config/i3/script/cpu.sh
interval=10

[ram]
command=sh ~/.config/i3/script/ram.sh
interval=10

[battery]
command=sh ~/.config/i3/script/battery.sh
interval=1

[datetime]
label= 
command=date '+%Y-%m-%d %H:%M:%S'
interval=1

